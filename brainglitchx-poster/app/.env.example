# Web app
PORT=3000
APP_PASSWORD=change-me-now
BASE_URL=https://bastiwe.de

# X API user-context credentials for @BrainGlitchX
# Create an X Developer App and enable read/write permissions.
X_APP_KEY=your_api_key
X_APP_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_token_secret

# Posting safety
TIMEZONE=Europe/Berlin
DRY_RUN=true

# Optional OpenAI generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional OpenAI image generation
# gpt-image-1 is recommended. You can change size if your account/model supports it.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Optional: true logs a scheduler heartbeat every minute
SCHEDULER_DEBUG=false

# Generator duplicate prevention
DEDUPE_MEMORY_LIMIT=300

# Analytics sync
ANALYTICS_AUTO_SYNC=false
ANALYTICS_CRON=17 * * * *
ANALYTICS_SYNC_LIMIT=50
# Keep false unless your X plan supports private/organic metrics. Public metrics include impressions when available.
ANALYTICS_PRIVATE_METRICS=false
